@using WebsterAptitude.Data
@using System.Security.Claims
@using System.Linq
@inject ApplicationDbContext Db

@{
    string? userId = User.FindFirstValue(ClaimTypes.NameIdentifier);

    var candidateProfile = (!string.IsNullOrEmpty(userId))
        ? Db.CandidateProfiles.FirstOrDefault(p => p.UserId == userId)
        : null;

    string displayName =
        (User.Identity != null && User.Identity.IsAuthenticated && User.IsInRole("Manager"))
            ? "Manager"
            : (candidateProfile?.FullName ?? (User.Identity?.Name ?? "Guest"));
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Webster Aptitude</title>

    @RenderSection("Styles", required: false)

    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />

    <!-- Bootstrap -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">

    <!-- Font -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">

    <style>
        body {
            font-family: 'Inter', sans-serif;
            padding-top: 72px; /* fixed navbar spacing */
            background-color: #f4f6f9;
        }

        /* NAVBAR */
        .navbar-glass {
            background: rgba(15, 23, 42, 0.9);
            backdrop-filter: blur(12px);
            border-bottom: 1px solid rgba(255,255,255,0.08);
        }

        .navbar-brand {
            letter-spacing: 0.3px;
        }

        .nav-link {
            color: #e5e7eb !important;
            font-weight: 500;
        }

            .nav-link:hover {
                color: #ffffff !important;
            }

        .profile-chip {
            background: rgba(255,255,255,0.08);
            border-radius: 999px;
            padding: 6px 14px;
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .profile-avatar {
            width: 34px;
            height: 34px;
            border-radius: 50%;
            background: linear-gradient(135deg, #6366f1, #22d3ee);
            display: flex;
            align-items: center;
            justify-content: center;
            color: white;
            font-weight: 600;
            font-size: 0.85rem;
        }

        .role-badge {
            font-size: 0.65rem;
            background: rgba(255,255,255,0.18);
            border-radius: 6px;
            padding: 2px 6px;
        }

        /* FOOTER */
        footer {
            background: #ffffff;
            border-top: 1px solid #e5e7eb;
            padding: 16px 0;
            margin-top: 40px;
        }

            footer a {
                text-decoration: none;
                font-weight: 500;
            }
    </style>
</head>

<body>

    <header>
        <nav class="navbar navbar-expand-lg navbar-dark navbar-glass fixed-top">
            <div class="container">

                <!-- Brand -->
                <a class="navbar-brand fw-bold d-flex align-items-center gap-2"
                   asp-controller="Home" asp-action="Index">
                    <span style="font-size:1.3rem">🧠</span>
                    <span>Webster Aptitude</span>
                </a>

                <!-- Mobile Toggle -->
                <button class="navbar-toggler" type="button"
                        data-bs-toggle="collapse"
                        data-bs-target="#mainNavbar">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <!-- Content -->
                <div class="collapse navbar-collapse justify-content-end" id="mainNavbar">
                    <ul class="navbar-nav align-items-center gap-3">

                        @if (User.Identity != null && User.Identity.IsAuthenticated)
                        {
                            <li class="nav-item">
                                <div class="profile-chip text-light">
                                    <div class="profile-avatar">
                                        @displayName.Substring(0, 1).ToUpper()
                                    </div>
                                    <div class="d-flex flex-column lh-sm">
                                        <span class="fw-semibold small">@displayName</span>
                                        <span class="role-badge">
                                            @(User.IsInRole("Manager") ? "Admin" : "Candidate")
                                        </span>
                                    </div>
                                </div>
                            </li>

                            @if (User.IsInRole("Manager"))
                            {
                                <li class="nav-item">
                                    <a class="nav-link"
                                       asp-controller="Manager"
                                       asp-action="Index">
                                        Dashboard
                                    </a>
                                </li>
                            }

                            @if (User.IsInRole("Candidate"))
                            {
                                <li class="nav-item">
                                    <a class="nav-link"
                                       asp-controller="Candidate"
                                       asp-action="Index">
                                        My Test
                                    </a>
                                </li>
                            }

                            <li class="nav-item">
                                <form asp-area="Identity"
                                      asp-page="/Account/Logout"
                                      method="post"
                                      class="d-inline">
                                    @Html.AntiForgeryToken()
                                    <button type="submit"
                                            class="btn btn-outline-light btn-sm px-3">
                                        Logout
                                    </button>
                                </form>


                            </li>
                        }
                        else
                        {
                            <li class="nav-item">
                                <a class="btn btn-outline-light btn-sm px-4"
                                   asp-area="Identity"
                                   asp-page="/Account/Login">
                                    Login
                                </a>
                            </li>
                        }

                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer>
        <div class="container d-flex justify-content-between align-items-center flex-wrap gap-2">
            <span class="text-muted small">
                © 2025 Webster Aptitude. All rights reserved.
            </span>
            <a asp-controller="Home" asp-action="Privacy" class="text-muted small">
                Privacy Policy
            </a>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>

    @await RenderSectionAsync("Scripts", required: false)

</body>
</html>
