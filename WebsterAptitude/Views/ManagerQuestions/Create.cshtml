@model WebsterAptitude.Models.Question

<h3 class="mb-3">Question</h3>

<form method="post">
    @Html.HiddenFor(m => m.Id)
    @Html.HiddenFor(m => m.SectionId)

    <div class="mb-3">
        <label class="form-label">Question</label>
        <textarea asp-for="QuestionText"
                  class="form-control"
                  rows="3"
                  required></textarea>
    </div>

    <div class="row">
        <div class="col-md-6 mb-2">
            <input asp-for="OptionA" class="form-control" placeholder="Option A" required />
        </div>
        <div class="col-md-6 mb-2">
            <input asp-for="OptionB" class="form-control" placeholder="Option B" required />
        </div>
        <div class="col-md-6 mb-2">
            <input asp-for="OptionC" class="form-control" placeholder="Option C" required />
        </div>
        <div class="col-md-6 mb-2">
            <input asp-for="OptionD" class="form-control" placeholder="Option D" required />
        </div>
    </div>

    <div class="row mt-2">
        <div class="col-md-6">
            <select asp-for="CorrectOption" class="form-select" required>
                <option value="">Correct Answer</option>
                <option>A</option>
                <option>B</option>
                <option>C</option>
                <option>D</option>
            </select>
        </div>

        <div class="col-md-6">
            <input asp-for="Marks"
                   type="number"
                   class="form-control"
                   min="1"
                   max="5" />
        </div>
    </div>

    <div class="mt-3">
        <button class="btn btn-success">Save</button>
        <a asp-action="Index"
           asp-route-sectionId="@Model.SectionId"
           class="btn btn-secondary">
            Back
        </a>
    </div>
</form>
