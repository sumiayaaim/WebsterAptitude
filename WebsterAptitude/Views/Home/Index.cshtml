<style>
    .hero {
        background: linear-gradient(135deg, #0f172a, #1e293b);
        color: white;
        border-radius: 20px;
        padding: 70px 60px;
        position: relative;
        overflow: hidden;
    }

        .hero::after {
            content: "";
            position: absolute;
            width: 500px;
            height: 500px;
            background: radial-gradient(circle, rgba(99,102,241,0.35), transparent);
            top: -150px;
            right: -150px;
        }

    .hero-btn {
        background: linear-gradient(135deg, #6366f1, #22d3ee);
        border: none;
        color: white;
        font-weight: 600;
        padding: 14px 30px;
        border-radius: 999px;
    }

        .hero-btn:hover {
            opacity: 0.9;
        }

    .feature-card {
        border-radius: 18px;
        padding: 35px;
        transition: all 0.3s ease;
        cursor: pointer;
    }

        .feature-card:hover {
            transform: translateY(-6px);
            box-shadow: 0 18px 40px rgba(0,0,0,0.12);
        }

    .stat {
        font-size: 2.2rem;
        font-weight: 700;
        background: linear-gradient(135deg, #6366f1, #22d3ee);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
    }
</style>
@{
    ViewData["Title"] = "Home";
}

<div class="container mt-5">
    @{
        ViewData["Title"] = "Home";
    }

    <div class="container mt-5">
        <div class="row align-items-center g-5">

            <!-- LEFT CONTENT -->
            <div class="col-md-6">
                <h1 class="fw-bold display-5">
                    Smart Aptitude Assessment Platform
                </h1>

                <p class="text-muted mt-3 fs-5">
                    Webster Aptitude helps organizations evaluate candidates through
                    structured, time-bound, and role-based aptitude tests.
                </p>

                <ul class="mt-3 text-muted">
                    <li>✔ General Knowledge, Mathematics & Technology</li>
                    <li>✔ Time-bound & section-wise evaluation</li>
                    <li>✔ Secure candidate & manager access</li>
                </ul>

                <div class="mt-4">
                    @if (User.Identity != null && User.Identity.IsAuthenticated)
                    {
                        <a asp-controller="Candidate"
                           asp-action="Index"
                           class="btn btn-primary btn-lg px-4">
                            Go to Dashboard
                        </a>
                    }
                    else
                    {
                        <a asp-area="Identity"
                           asp-page="/Account/Login"
                           class="btn btn-primary btn-lg px-4">
                            Get Started
                        </a>
                    }
                </div>
            </div>

            <!-- RIGHT IMAGE -->
            <div class="col-md-6 text-center">
                <img src="https://illustrations.popsy.co/gray/work-from-home.svg"
                     alt="Online Assessment"
                     class="img-fluid"
                     style="max-height:420px;">
            </div>

        </div>
    </div>

    <!-- FEATURE STRIP -->
    <div class="container mt-5">
        <div class="row text-center g-4">

            <div class="col-md-4">
                <div class="card p-4 h-100">
                    <h5 class="fw-semibold">Structured Tests</h5>
                    <p class="text-muted mt-2">
                        Section-wise aptitude tests with controlled flow.
                    </p>
                </div>
            </div>

            <div class="col-md-4">
                <div class="card p-4 h-100">
                    <h5 class="fw-semibold">Role Based Access</h5>
                    <p class="text-muted mt-2">
                        Dedicated dashboards for Managers and Candidates.
                    </p>
                </div>
            </div>

            <div class="col-md-4">
                <div class="card p-4 h-100">
                    <h5 class="fw-semibold">Instant Results</h5>
                    <p class="text-muted mt-2">
                        Automatic evaluation and eligibility decision.
                    </p>
                </div>
            </div>

        </div>
    </div>

