@using WebsterAptitude.Models
@using System.Collections.Generic

@{
    ViewData["Title"] = "Candidate Dashboard";

    bool hasStarted = ViewBag.HasStarted != null && (bool)ViewBag.HasStarted;

    var sections = hasStarted
        ? (ViewBag.Sections as List<TestSection> ?? new List<TestSection>())
        : new List<TestSection>();

    var completed = hasStarted
        ? (ViewBag.Completed as List<int> ?? new List<int>())
        : new List<int>();

    int total = sections.Count;
    int done = completed.Count;
    int percent = total > 0 ? (int)((double)done / total * 100) : 0;

    // Result values (safe defaults)
    int score = ViewBag.Score ?? 0;
    int maxScore = ViewBag.MaxScore ?? 100;
    string resultStatus = ViewBag.ResultStatus ?? "";
}

@section Styles {
    <style>
        /* ============================
           DASHBOARD BASE
           ============================ */
        .dashboard-wrapper {
            padding: 60px 0;
        }

        .dashboard-header h2 {
            font-weight: 700;
            color: #0f172a;
        }

        .dashboard-header p {
            color: #475569;
            margin-top: 6px;
        }

        /* ============================
           PROGRESS CARD
           ============================ */
        .progress-card {
            background: #ffffff;
            border-radius: 16px;
            padding: 24px;
            box-shadow: 0 12px 30px rgba(0,0,0,0.06);
        }

        .progress-meta {
            font-size: 0.9rem;
            color: #64748b;
        }

        /* ============================
           SECTION CARDS
           ============================ */
        .section-card {
            border-radius: 14px;
            padding: 20px;
            background: #ffffff;
            box-shadow: 0 10px 25px rgba(0,0,0,0.06);
            display: flex;
            justify-content: space-between;
            align-items: center;
            transition: transform .2s ease;
        }

            .section-card:hover {
                transform: translateY(-4px);
            }

        .section-name {
            font-weight: 600;
            color: #0f172a;
        }

        /* States */
        .section-completed {
            border-left: 5px solid #22c55e;
        }

        .section-active {
            border-left: 5px solid #14b8a6;
        }

        .section-locked {
            border-left: 5px solid #94a3b8;
            opacity: 0.6;
        }

        /* Buttons */
        .btn-start {
            background: linear-gradient(135deg, #0d9488, #14b8a6);
            color: #fff;
            border-radius: 999px;
            padding: 6px 18px;
            font-size: 0.85rem;
            font-weight: 600;
        }

        .badge-completed {
            background: #22c55e;
        }

        .badge-locked {
            background: #94a3b8;
        }

        /* ============================
           RESULT SUMMARY
           ============================ */
        .result-card {
            margin-top: 60px;
            background: linear-gradient(135deg, #f8fafc, #ffffff);
            border-radius: 18px;
            padding: 32px;
            box-shadow: 0 14px 35px rgba(0,0,0,0.08);
        }

        .result-title {
            font-weight: 700;
            color: #0f172a;
        }

        .result-score {
            font-size: 3rem;
            font-weight: 800;
            color: #0d9488;
        }

        .result-meta {
            color: #475569;
            margin-top: 6px;
        }

        .result-pass {
            color: #16a34a;
            font-weight: 600;
        }

        .result-fail {
            color: #dc2626;
            font-weight: 600;
        }
    </style>
}

<div class="dashboard-wrapper">
    <div class="container">

        <!-- Header -->
        <div class="dashboard-header mb-4">
            <h2>Aptitude Test Dashboard</h2>
            <p>Track your progress and complete each section in sequence.</p>
        </div>

        @if (!hasStarted)
        {
            <!-- Pre-start Card -->
            <div class="progress-card text-center">
                <h5>You’re about to begin your aptitude assessment</h5>
                <p class="progress-meta mt-2">
                    Once started, sections must be completed in order.
                </p>

                <a asp-action="StartTest" class="btn btn-start mt-3">
                    Start Aptitude Test
                </a>
            </div>
        }
        else
        {
            <!-- Progress Overview -->
            <div class="progress-card mb-5">
                <div class="d-flex justify-content-between mb-2">
                    <span class="fw-semibold">Overall Progress</span>
                    <span class="progress-meta">@done of @total sections completed</span>
                </div>

                <div class="progress" style="height:18px;">
                    <div class="progress-bar bg-success"
                         role="progressbar"
                         style="width:@percent%">
                        @percent%
                    </div>
                </div>
            </div>

            <!-- Sections -->
            <div class="row g-4">
                @for (int i = 0; i < sections.Count; i++)
                {
                    var s = sections[i];
                    bool canAccess = i == 0 || completed.Contains(sections[i - 1].Id);
                    bool isDone = completed.Contains(s.Id);

                    string stateClass = isDone
                    ? "section-completed"
                    : canAccess
                    ? "section-active"
                    : "section-locked";

                    <div class="col-md-6">
                        <div class="section-card @stateClass">
                            <div>
                                <div class="section-name">@s.Name</div>
                                <div class="progress-meta">
                                    Section @(i + 1) of @total
                                </div>
                            </div>

                            <div>
                                @if (isDone)
                                {
                                    <span class="badge badge-completed">Completed</span>
                                }
                                else if (canAccess)
                                {
                                    <a asp-controller="Candidate"
                                       asp-action="StartSection"
                                       asp-route-sectionId="@s.Id"
                                       class="btn btn-start">
                                        Start
                                    </a>
                                }
                                else
                                {
                                    <span class="badge badge-locked">Locked</span>
                                }
                            </div>
                        </div>
                    </div>
                }
            </div>

            <!-- Result Summary (ONLY ONCE, AFTER ALL SECTIONS) -->
            @if (done == total && total > 0)
            {
                <div class="result-card">
                    <div class="row align-items-center">
                        <div class="col-md-8">
                            <h4 class="result-title">Assessment Result</h4>

                            <p class="result-meta">
                                You have successfully completed all sections of the aptitude test.
                            </p>

                            <p class="mt-3">
                                Status:
                                @if (resultStatus == "Pass")
                                {
                                    <span class="result-pass">Passed</span>
                                }
                                else if (resultStatus == "Fail")
                                {
                                    <span class="result-fail">Failed</span>
                                }
                                else
                                {
                                    <span class="fw-semibold">Result Pending</span>
                                }
                            </p>
                        </div>

                        <div class="col-md-4 text-center">
                            <div class="result-score">
                                @score / @maxScore
                            </div>
                            <div class="result-meta">Final Score</div>
                        </div>
                    </div>
                </div>
            }
        }

    </div>
</div>
