@model List<WebsterAptitude.Models.Question>

<div class="d-flex justify-content-between align-items-center mb-4 pb-3 border-bottom">
    <div>
        <h4 class="fw-semibold mb-1">Aptitude Test</h4>
        <small class="text-muted">Answer all questions before time expires</small>
    </div>

    <span class="badge bg-danger fs-6 px-3 py-2">
        ⏱ Time Remaining: <span id="timer"></span>
    </span>
</div>


        <script>
            let seconds = @(ViewBag.TimeLimitSeconds ?? 300);

            function updateTimer() {
                const min = Math.floor(seconds / 60);
                const sec = seconds % 60;
                document.getElementById("timer").innerText =
                    min + ":" + (sec < 10 ? "0" + sec : sec);

                if (seconds <= 0) {
                    document.forms[0].submit();
                }
                seconds--;
            }

            setInterval(updateTimer, 1000);
            updateTimer();
        </script>

        <form method="post"
              asp-controller="Candidate"
              asp-action="SubmitSection">

            @Html.AntiForgeryToken()

            @for (int i = 0; i < Model.Count; i++)
            {
                <div class="mb-4">
                    <p class="fw-semibold">@(@i + 1). @Model[i].QuestionText</p>

                    @foreach (var opt in new[] {
                                ("A", Model[i].OptionA),
                                ("B", Model[i].OptionB),
                                ("C", Model[i].OptionC),
                                ("D", Model[i].OptionD)
                                })
                    {
                        <div class="form-check">
                            <input class="form-check-input"
                                   type="radio"
                                   name="answers[@i]"
                                   value="@opt.Item1"
                                   required />
                            <label class="form-check-label">
                                @opt.Item2
                            </label>
                        </div>
                    }

                    <input type="hidden" name="questionIds[@i]" value="@Model[i].Id" />
                </div>
                <hr />
            }

            <button type="submit" class="btn btn-primary w-100">
                Submit Section
            </button>
        </form>
    </div>
</div>
